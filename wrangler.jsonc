{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "startup-os",
  "main": "apps/web/dist/server/index.js",
  "compatibility_date": "2026-05-20",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "apps/web/dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
